---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
// import EnvelopeLab from "@/components/labs/hu";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import {
  TypographyH2,
  TypographyH4,
  TypographyP,
} from "@/components/ui/typography";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      #colors td,
      #colors th {
        padding: 0.25rem 0.5rem;
      }
      #colors {
        border-width: 2px;
      }
    </style>
  </head>
  <body>
    <Header />
    <main class:list={["container-lg", "py-4", "mb-24"]}>
      <TypographyH2>Carbon Cycle Game</TypographyH2>
      <TypographyP
        >This activity is a digitized version of <a
          href="https://nagt.org/nagt/teaching_resources/teachingmaterials/57695.html"
          target="_blank"
          class="hover:underline no-underline font-semibold text-orange-500"
          >this lesson</a
        > by Cheryl Manning.</TypographyP
      >
      <TypographyH4 classes={["my-4"]}>The Game</TypographyH4>
      <div id="game" class="flex flex-col gap-2 mb-2"></div>
      <Button id="next" variant="default">Advance to Next Reservoir</Button>
      <Button id="changeRound" variant="secondary">Go to Next Round</Button>
    </main>
  </body>
</html>

