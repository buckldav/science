  const round2 = {
    Atmosphere: atmosphere2,
    "Deep Ocean": deepOcean2,
    "Fossil Fuels": fossilFuels2,
    "Marine Biosphere": marineBiosphere2,
    "Ocean's Surface": oceansSurface2,
    Rocks: rocks2,
    Soil: soil2,
    "Terrestrial Plants": terrestrialPlants2,
  };

  const rounds = [round1, round2];

  const state = {
    currentRound: -1,
    currentReservoir: "",
  };

  const gameDiv = document.getElementById("game")!;
  const nextButton = document.getElementById("next")!;
  const roundButton = document.getElementById("changeRound")!;

  function advanceRound() {
    state.currentRound = (state.currentRound + 1) % 2;
  }

  function setReservoir() {
    const reservoirs = Object.keys(rounds[state.currentRound]);
    const index = Math.floor(Math.random() * reservoirs.length);
    state.currentReservoir = reservoirs[index];
  }

  function getDiceRoll() {
    return Math.floor(Math.random() * 6);
  }

  function renderGameState() {
    const [event, nextReservoir] =
      rounds[state.currentRound][state.currentReservoir][getDiceRoll()];
    const roundText =
      state.currentRound === 0
        ? "Round 1 (before human interference)"
        : "Round 2 (human interference)";
    gameDiv.innerHTML = `
      <p><span class="font-bold">Current Round: </span>${roundText}</p>
      <p><span class="font-bold">Current Reservoir: </span>${state.currentReservoir}</p>
      <p><span class="font-bold">What Happened: </span>${event}</p>
      <br>
    `;
    state.currentReservoir = nextReservoir;
  }

  function startRound() {
    advanceRound();
    setReservoir();
    renderGameState();
  }

  startRound();

  nextButton.onclick = (e) => {
    renderGameState();
  };

  roundButton.onclick = (e) => {
    startRound();
  };
</script>
